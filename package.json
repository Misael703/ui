{
  "name": "@misael703/ui",
  "version": "1.53.0",
  "description": "Generic React + TypeScript UI kit, optimized for Next.js. Tokens, accessible components, runtime-configurable theming via presets.",
  "author": "Misael Ocas <misael.ocas@gmail.com>",
  "license": "MIT",
  "type": "commonjs",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Misael703/ui.git"
  },
  "homepage": "https://github.com/Misael703/ui#readme",
  "bugs": {
    "url": "https://github.com/Misael703/ui/issues"
  },
  "keywords": [
    "react",
    "nextjs",
    "ui-kit",
    "design-system",
    "components",
    "typescript",
    "tailwind-alternative"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./cl": {
      "import": {
        "types": "./dist/cl/index.d.mts",
        "default": "./dist/cl/index.mjs"
      },
      "require": {
        "types": "./dist/cl/index.d.ts",
        "default": "./dist/cl/index.js"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./fonts.css": "./dist/fonts.css",
    "./tokens.css": "./dist/tokens.css",
    "./fonts/*": "./dist/fonts/*",
    "./presets/elalba": "./dist/presets/elalba/styles.css",
    "./presets/elalba-defaults": {
      "import": {
        "types": "./dist/presets/elalba/defaults.d.mts",
        "default": "./dist/presets/elalba/defaults.mjs"
      },
      "require": {
        "types": "./dist/presets/elalba/defaults.d.ts",
        "default": "./dist/presets/elalba/defaults.js"
      }
    },
    "./presets/elalba-logos/*": "./dist/presets/elalba/logos/*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs && npm run build:css && mkdir -p dist/fonts && cp src/fonts/*.woff2 src/fonts/OFL.txt dist/fonts/ && mkdir -p dist/presets/elalba/logos && cp src/presets/elalba/logos/* dist/presets/elalba/logos/",
    "build:css": "postcss src/styles/index.css -o dist/styles.css && postcss src/styles/fonts.css -o dist/fonts.css && postcss src/styles/tokens.css -o dist/tokens.css && mkdir -p dist/presets/elalba && postcss src/presets/elalba/styles.css -o dist/presets/elalba/styles.css",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "smoke:ci": "node scripts/smoke-ci.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^8.3.0",
    "@storybook/addon-essentials": "^8.3.0",
    "@storybook/react": "^8.3.0",
    "@storybook/react-vite": "^8.3.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.12",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^3.8.1",
    "storybook": "^8.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
