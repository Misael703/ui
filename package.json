{
  "name": "@misael703/elalba-ui",
  "version": "0.4.1",
  "description": "UI Kit React + TypeScript multi-marca, optimizado para Next.js. Tokens, componentes accesibles y branding configurable en runtime.",
  "author": "Misael Ocas <misael.ocas@gmail.com>",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Misael703/elalba-ui.git"
  },
  "homepage": "https://github.com/Misael703/elalba-ui#readme",
  "bugs": {
    "url": "https://github.com/Misael703/elalba-ui/issues"
  },
  "keywords": [
    "react",
    "nextjs",
    "ui-kit",
    "design-system",
    "components",
    "typescript",
    "tailwind-alternative"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./fonts.css": "./dist/fonts.css",
    "./tokens.css": "./dist/tokens.css",
    "./fonts/*": "./dist/fonts/*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && npm run build:css && mkdir -p dist/fonts && cp src/fonts/*.otf src/fonts/*.woff2 src/fonts/OFL.txt dist/fonts/",
    "build:css": "postcss src/styles/index.css -o dist/styles.css && postcss src/styles/fonts.css -o dist/fonts.css && postcss src/styles/tokens.css -o dist/tokens.css",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.3.0",
    "@storybook/addon-essentials": "^8.3.0",
    "@storybook/react": "^8.3.0",
    "@storybook/react-vite": "^8.3.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.7",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.12",
    "postcss-cli": "^11.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^3.8.1",
    "storybook": "^8.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
